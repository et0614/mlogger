<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:MLS_Mobile"
             xmlns:res="clr-namespace:MLS_Mobile.Resources.i18n"
             x:Class="MLS_Mobile.MLoggerScanner"
             Title="{x:Static res:MLSResource.SC_Title}">

    <RefreshView x:Name="refView">
        <Grid RowDefinitions="Auto,*,Auto">
            <!-- Demo モード: 実機なしで UI 確認用 (DummyMLProtocol 経由)。
                 通常時は非表示で、シェイクで切り替え。v3/v4 firmware 相当の UI 切替を確認可能。 -->
            <Grid x:Name="demoBtn" Grid.Row="0" IsVisible="False" ColumnDefinitions="*,*" Margin="10,5" ColumnSpacing="5">
                <Button Grid.Column="0" Text="Demo (v4)" Clicked="DemoButtonV4_Clicked"
                        Padding="5"
                        BackgroundColor="{StaticResource Light_G}" TextColor="{StaticResource Darkest_G}"/>
                <Button Grid.Column="1" Text="Demo (v3)" Clicked="DemoButtonV3_Clicked"
                        Padding="5"
                        BackgroundColor="{StaticResource Light_G}" TextColor="{StaticResource Darkest_G}"/>
            </Grid>
            <CollectionView Grid.Row="1"
                x:Name="mlList" ItemsSource="{ Binding MLXBees }" SelectionMode="Single" SelectionChanged="mlList_SelectionChanged">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <local:IDeviceView Padding="0"/>
                    </DataTemplate>
                </CollectionView.ItemTemplate>

                <CollectionView.EmptyView>
                    <Grid
                        Padding="5"
                        RowDefinitions="Auto, *"
                        ColumnDefinitions="*"
                        RowSpacing="5"
                        ColumnSpacing="5">
                        <Label
                            Grid.Row="0" Grid.Column="0"
                            Text="{x:Static res:MLSResource.SC_Empty}"
                            FontSize="18"
                            HorizontalOptions="Start"
                            VerticalOptions="Center" Padding="5"/>
                    </Grid>
                </CollectionView.EmptyView>
            </CollectionView>

            <!--公式サイトリンク (控えめにフッタに配置)-->
            <Label Grid.Row="2"
                   Text="mlogger.jp"
                   FontSize="12"
                   TextColor="{StaticResource Dark_G}"
                   TextDecorations="Underline"
                   HorizontalTextAlignment="Center"
                   Padding="0,8,0,8">
                <Label.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnSiteLinkTapped"/>
                </Label.GestureRecognizers>
            </Label>

            <!--インジケータ (Grid 全体を覆う)-->
            <ContentView x:Name="grayback" Grid.RowSpan="3" IsVisible="False" BackgroundColor="Black" Opacity="0.4" AbsoluteLayout.LayoutFlags="All" AbsoluteLayout.LayoutBounds="0,0,1,1"/>
            <Border x:Name="indicator" Grid.RowSpan="3" IsVisible="False" BackgroundColor="White" AnchorX="0.5" HorizontalOptions="Center" VerticalOptions="Center" StrokeShape="RoundRectangle 10" Padding="15">
                <StackLayout BackgroundColor="White">
                    <ActivityIndicator Color="Black" IsRunning="True"/>
                    <Label x:Name="indicatorLabel" Text="---" TextColor="Black"/>
                </StackLayout>
            </Border>
            <!--インジケータここまで-->
        </Grid>
    </RefreshView>
</ContentPage>
