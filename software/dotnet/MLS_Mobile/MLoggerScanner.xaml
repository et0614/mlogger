<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:MLS_Mobile"
             xmlns:res="clr-namespace:MLS_Mobile.Resources.i18n"
             x:Class="MLS_Mobile.MLoggerScanner"
             Title="{x:Static res:MLSResource.SC_Title}">

    <RefreshView x:Name="refView">
        <Grid RowDefinitions="Auto,*">
            <!-- Demo モード: 実機なしで UI 確認用 (DummyMLProtocol 経由) -->
            <Button Grid.Row="0" Text="Open Demo Device" Clicked="DemoButton_Clicked"
                    Margin="10,5" Padding="5"
                    BackgroundColor="{StaticResource Light_G}" TextColor="{StaticResource Darkest_G}"/>
            <CollectionView Grid.Row="1"
                x:Name="mlList" ItemsSource="{ Binding MLXBees }" SelectionMode="Single" SelectionChanged="mlList_SelectionChanged">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <local:IDeviceView Padding="0"/>
                    </DataTemplate>
                </CollectionView.ItemTemplate>

                <CollectionView.EmptyView>
                    <Grid 
                        Padding="5" 
                        RowDefinitions="Auto, *"
                        ColumnDefinitions="*" 
                        RowSpacing="5"
                        ColumnSpacing="5">
                        <Label 
                            Grid.Row="0" Grid.Column="0"
                            Text="{x:Static res:MLSResource.SC_Empty}" 
                            FontSize="18"
                            HorizontalOptions="Start"
                            VerticalOptions="Center" Padding="5"/>
                    </Grid>
                </CollectionView.EmptyView>
            </CollectionView>

            <!--インジケータ (Grid 全体を覆う)-->
            <ContentView x:Name="grayback" Grid.RowSpan="2" IsVisible="False" BackgroundColor="Black" Opacity="0.4" AbsoluteLayout.LayoutFlags="All" AbsoluteLayout.LayoutBounds="0,0,1,1"/>
            <Border x:Name="indicator" Grid.RowSpan="2" IsVisible="False" BackgroundColor="White" AnchorX="0.5" HorizontalOptions="Center" VerticalOptions="Center" StrokeShape="RoundRectangle 10" Padding="15">
                <StackLayout BackgroundColor="White">
                    <ActivityIndicator Color="Black" IsRunning="True"/>
                    <Label x:Name="indicatorLabel" Text="---" TextColor="Black"/>
                </StackLayout>
            </Border>
            <!--インジケータここまで-->
        </Grid>
    </RefreshView>
</ContentPage>
