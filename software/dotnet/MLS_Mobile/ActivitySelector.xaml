<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MLS_Mobile.ActivitySelector"
             xmlns:res="clr-namespace:MLS_Mobile.Resources.i18n"
             Title="{x:Static res:TCResource.SelectActivity}"
             xmlns:local="clr-namespace:MLS_Mobile"
             x:DataType="local:ActivitySelector"
             >

    <Grid>
        <CollectionView x:Name="actView"
                        ItemsSource="{Binding Activities}" IsGrouped="true" SelectionMode="Single"
                        SelectionChanged="OnCollectionViewSelectionChanged">
            <CollectionView.ItemsLayout>
                <GridItemsLayout Orientation="Vertical" Span="2"
                                 HorizontalItemSpacing="8" VerticalItemSpacing="8"/>
            </CollectionView.ItemsLayout>
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="local:Activity">
                    <Grid Padding="8" RowDefinitions="Auto,Auto,Auto" HorizontalOptions="Fill">
                        <VisualStateManager.VisualStateGroups>
                            <VisualStateGroup x:Name="CommonStates">
                                <VisualState x:Name="Normal">
                                    <VisualState.Setters>
                                        <Setter Property="BackgroundColor" Value="Transparent"/>
                                    </VisualState.Setters>
                                </VisualState>
                                <VisualState x:Name="Selected">
                                    <VisualState.Setters>
                                        <Setter Property="BackgroundColor" Value="{StaticResource Light_G}"/>
                                    </VisualState.Setters>
                                </VisualState>
                            </VisualStateGroup>
                        </VisualStateManager.VisualStateGroups>
                        <Border Grid.Row="0"
                                StrokeShape="RoundRectangle 12"
                                Stroke="{StaticResource Dark_G}"
                                StrokeThickness="1"
                                Padding="4"
                                HorizontalOptions="Center">
                            <Image Source="{Binding Appearance}" Aspect="AspectFit"
                                   HeightRequest="140" WidthRequest="140"/>
                        </Border>
                        <Label Grid.Row="1" Text="{Binding Name}"
                               FontSize="14" FontAttributes="Bold"
                               HorizontalTextAlignment="Center"
                               LineBreakMode="WordWrap"
                               Margin="0,6,0,0"/>
                        <Label Grid.Row="2" Text="{Binding MetValue, StringFormat='{0:F2} met'}"
                               FontSize="12"
                               HorizontalTextAlignment="Center"/>
                    </Grid>
                </DataTemplate>
            </CollectionView.ItemTemplate>
            <CollectionView.GroupHeaderTemplate>
                <DataTemplate x:DataType="local:ActivityGroup">
                    <Label Text="{Binding Name}"
                           TextColor="White"
                           BackgroundColor="{StaticResource Dark_G}"
                           FontSize="20"
                           FontAttributes="Bold" Padding="10,0,0,0" />
                </DataTemplate>
            </CollectionView.GroupHeaderTemplate>
        </CollectionView>
    </Grid>
</ContentPage>