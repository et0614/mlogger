<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MLS_Mobile.LogView"
             xmlns:res="clr-namespace:MLS_Mobile.Resources.i18n"
             BackgroundColor="White"
             Title="LogView">
    <Grid RowDefinitions="*,Auto,Auto,Auto" BackgroundColor="White">

        <!-- ログ表示 (Editor で IsReadOnly: iOS でも TextColor が安定して効く) -->
        <Editor Grid.Row="0"
                x:Name="logEditor"
                Text=""
                IsReadOnly="True"
                BackgroundColor="White"
                TextColor="Black"
                FontSize="Small"
                Margin="10" />

        <BoxView Grid.Row="1" HeightRequest="1" BackgroundColor="{StaticResource Darkest_G}" HorizontalOptions="FillAndExpand" />

        <!-- Clear ボタン -->
        <Button Grid.Row="2" Text="Clear log" Margin="10,10,10,0" VerticalOptions="Center" HorizontalOptions="Fill" Clicked="clear_Clicked" FontSize="Medium">
            <Button.ImageSource>
                <FontImageSource Glyph="&#xf2ed;" FontFamily="FAS" Size="20" Color="{StaticResource Dark_G}"/>
            </Button.ImageSource>
        </Button>

        <!-- Share ボタン -->
        <Button Grid.Row="3" Text="{x:Static res:MLSResource.LD_Share}" Margin="10" VerticalOptions="Center" HorizontalOptions="Fill" Clicked="share_Clicked" FontSize="Medium">
            <Button.ImageSource>
                <FontImageSource Glyph="&#xe09a;" FontFamily="FAS" Size="24" Color="{StaticResource Dark_G}"/>
            </Button.ImageSource>
        </Button>

    </Grid>
</ContentPage>
